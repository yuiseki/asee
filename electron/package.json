{
  "name": "asee-electron",
  "version": "0.1.0",
  "private": true,
  "description": "Electron viewer shell for agentic seeing",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "demo": "node ./scripts/run-electron-with-x11-env.mjs --auto-demo --exit-after-demo",
    "start": "node ./scripts/run-electron-with-x11-env.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "electron": "^35.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^3.0.8"
  }
}
